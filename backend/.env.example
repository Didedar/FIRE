# FIRE Backend Environment Variables

# Groq API Key (required for AI analysis)
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL Database URL
DATABASE_URL=postgresql://fire_user:fire_password@localhost:5433/fire_db
DATABASE_URL_ASYNC=postgresql+asyncpg://fire_user:fire_password@localhost:5433/fire_db

# Processing Settings (optional)
BATCH_SEMAPHORE_LIMIT=10
TICKET_PROCESSING_TIMEOUT=10.0
